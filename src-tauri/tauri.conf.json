{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LeakGuard CaseDesk",
  "version": "1.0.0",
  "identifier": "com.leakguard.casedesk",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LeakGuard CaseDesk",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "pt-BR"
      },
      "nsis": {
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false
      }
    },
    "publisher": "LeakGuard Security",
    "copyright": "Copyright © 2025 LeakGuard Security",
    "category": "Business",
    "shortDescription": "DLP Incident Investigation Platform",
    "longDescription": "LeakGuard CaseDesk é uma plataforma de investigação e triagem de incidentes DLP para times de Segurança da Informação e SOC."
  }
}
